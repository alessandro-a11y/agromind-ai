# URL base da API ASP.NET Core
# Em desenvolvimento: deixe vazio (Vite proxy cuida do redirecionamento)
# Em produção (Render): configure no painel como variável de ambiente
VITE_API_URL=

# URL do serviço FastAPI (IA)
# Em desenvolvimento: http://localhost:8000
# Em produção (Render): configure no painel
VITE_FASTAPI_URL=
